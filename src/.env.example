# Neon Postgres connection strings.
# Create with: neonctl connection-string --project-id <id> --database-name <db> --role-name <role>
# Format: postgres://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL_PROD=postgres://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL_TEST=postgres://USER:PASSWORD@HOST/DATABASE?sslmode=require

# DB_ENV: "prod" or "test" (default: test in Docker, prod when running locally)
# Controls which DATABASE_URL_* is used.
DB_ENV=test

# RESEED_TEST_DB: set to "true" to wipe and reseed the test database on startup.
# Ignored when DB_ENV=prod. After reseeding, set back to "false".
RESEED_TEST_DB=false
